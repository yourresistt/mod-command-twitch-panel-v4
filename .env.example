# Twitch Developer Console — register a new application of type "Other"/"Confidential client"
# https://dev.twitch.tv/console/apps

# Public Client ID
TWITCH_CLIENT_ID=your_client_id_here

# Confidential client secret — server only. Never commit. Regenerate if leaked.
TWITCH_CLIENT_SECRET=your_client_secret_here

# Must match exactly one entry in your Twitch app's "OAuth Redirect URLs".
# Local dev:
TWITCH_REDIRECT_URI=http://localhost:5000/api/twitch/callback
# Production (Render) example:
# TWITCH_REDIRECT_URI=https://twitch-mod-commandv3.onrender.com/api/twitch/callback

# Express port (Render injects PORT automatically; defaults to 5000 locally)
PORT=5000
